// Prisma schema for MySQL (production)
// PostgreSQL available for dev
// Set your DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  superadmin
  trader
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String            @unique
  emailVerified   DateTime?
  image           String?
  credential      Credential?
  role            UserRole          @default(user)
  isApproved      Boolean           @default(false)
  isActive        Boolean           @default(true) // For disabling/banning users
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  profile         UserInformation?
  accounts        Account[]
  sessions        Session[]
  auditLogs       UserAuditLog[]    @relation("PerformedBy")
  receivedLogs    UserAuditLog[]    @relation("TargetUser")
  mt5Account      Mt5Account?
  tradeCopierAccounts TradeCopierAccount[]
  eaConfigs       EaConfig[]
  botAssignments  BotAssignment[]
  tradingModels   TradingModel[]
  modelConfigs    ModelConfig[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Credential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserInformation {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName  String?
  lastName   String?
  company    String?
  city       String?
  country    String?
  phone      String?
  email      String?
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Mt5Account {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  login     String   
  password  String   // Encrypted
  server    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  tradeCopierAccount TradeCopierAccount?
}

model TradeCopierAccount {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mt5AccountId      String?     @unique
  mt5Account        Mt5Account? @relation(fields: [mt5AccountId], references: [id], onDelete: SetNull)
  
  account_id        String      @unique // ID en Trade Copier
  name              String
  type              Int         // 0=Master, 1=Slave
  broker            String
  login             String
  password          String      // Encriptado
  server            String
  environment       String?
  status            Int         @default(1)
  
  groupid           String?
  subscription_key  String?
  ccy               String?
  balance           Float?
  equity            Float?
  state             String?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
}

model EaConfig {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  eaName            String
  magicNumber       Int             @unique
  symbol            String
  timeframe         String
  lotSize           Float
  stopLoss          Int
  takeProfit        Int
  maxTrades         Int
  tradingHoursStart Int
  tradingHoursEnd   Int
  riskPercent       Float
  enabled           Boolean         @default(true)
  customParams      Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  botAssignments    BotAssignment[]

  @@index([userId])
}

model BotAssignment {
  id          String   @id @default(cuid())
  userId      String
  magicNumber Int
  assignedAt  DateTime @default(now())
  
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eaConfig EaConfig @relation(fields: [magicNumber], references: [magicNumber], onDelete: Cascade)
  
  @@unique([userId, magicNumber])
  @@index([userId])
  @@index([magicNumber])
}

model UserAuditLog {
  id            String   @id @default(cuid())
  action        String   // APPROVE, REJECT, DISABLE, ENABLE
  details       String?
  performedById String
  performedBy   User     @relation("PerformedBy", fields: [performedById], references: [id], onDelete: Cascade)
  targetUserId  String?
  targetUser    User?    @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([performedById])
  @@index([targetUserId])
}

// ─── NUEVOS MODELOS (Trading Models & Configs) ───────────────────────────────

model ModelConfig {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name              String         // E.g., "Configuracion Agresiva"
  description       String?
  
  // Settings técnicos (equivalente a CopySettings)
  risk_factor_value Float
  risk_factor_type  Int
  copier_status     Int            @default(1)
  
  max_order_size    Float?
  min_order_size    Float?
  
  pending_order     Int            @default(1)
  stop_loss         Int            @default(0)
  take_profit       Int            @default(0)
  stop_loss_fixed_format   Int     @default(2)
  take_profit_fixed_format Int     @default(2)
  
  // JSON field for all other advanced settings to avoid schema bloat
  advancedSettings  Json?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tradingModels     TradingModel[]

  @@index([userId])
}

model TradingModel {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  masterAccountId   String         // El ID de la cuenta en tradeCopierAccount (type 0)
  configId          String
  modelConfig       ModelConfig    @relation(fields: [configId], references: [id], onDelete: Restrict)
  
  name              String         // UI display name (e.g., "Gold Scalper Pro")
  description       String?
  isPublic          Boolean        @default(false)
  group_id          String?        // ID de la API externa (Template/Group)
  ownerId           String?        // ID del creador original
  isClone           Boolean        @default(false)
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([configId])
}

