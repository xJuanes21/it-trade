generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?
  image               String?
  role                UserRole             @default(user)
  isApproved          Boolean              @default(false)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  botAssignments      BotAssignment[]
  credential          Credential?
  credentialsApi      CredentialsApi?
  eaConfigs           EaConfig[]
  modelConfigs        ModelConfig[]
  mt5Account          Mt5Account?
  sessions            Session[]
  syncConfigs         SyncConfig[]
  tradeCopierAccounts TradeCopierAccount[]
  tradingModels       TradingModel[]
  auditLogs           UserAuditLog[]       @relation("PerformedBy")
  receivedLogs        UserAuditLog[]       @relation("TargetUser")
  profile             UserInformation?
  sentRequests        CopyRequest[]        @relation("SentRequests")
  receivedRequests    CopyRequest[]        @relation("ReceivedRequests")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Credential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserInformation {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String?
  lastName  String?
  company   String?
  city      String?
  country   String?
  phone     String?
  email     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Mt5Account {
  id                 String              @id @default(cuid())
  userId             String              @unique
  login              String
  password           String
  server             String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeCopierAccount TradeCopierAccount?
}

model TradeCopierAccount {
  id               String      @id @default(cuid())
  userId           String
  mt5AccountId     String?     @unique
  account_id       String      @unique
  name             String
  type             Int
  broker           String
  login            String
  password         String
  server           String
  environment      String?
  status           Int         @default(1)
  groupid          String?
  subscription_key String?
  ccy              String?
  balance          Float?
  equity           Float?
  state            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  mt5Account       Mt5Account? @relation(fields: [mt5AccountId], references: [id])
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EaConfig {
  id                String          @id @default(cuid())
  userId            String
  eaName            String
  magicNumber       Int             @unique
  symbol            String
  timeframe         String
  lotSize           Float
  stopLoss          Int
  takeProfit        Int
  maxTrades         Int
  tradingHoursStart Int
  tradingHoursEnd   Int
  riskPercent       Float
  enabled           Boolean         @default(true)
  customParams      Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  botAssignments    BotAssignment[]
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BotAssignment {
  id          String   @id @default(cuid())
  userId      String
  magicNumber Int
  assignedAt  DateTime @default(now())
  eaConfig    EaConfig @relation(fields: [magicNumber], references: [magicNumber], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, magicNumber])
  @@index([userId])
  @@index([magicNumber])
}

model UserAuditLog {
  id            String   @id @default(cuid())
  action        String
  details       String?
  performedById String
  targetUserId  String?
  createdAt     DateTime @default(now())
  performedBy   User     @relation("PerformedBy", fields: [performedById], references: [id], onDelete: Cascade)
  targetUser    User?    @relation("TargetUser", fields: [targetUserId], references: [id])

  @@index([performedById])
  @@index([targetUserId])
}

model ModelConfig {
  id                       String         @id @default(cuid())
  userId                   String
  name                     String
  description              String?
  risk_factor_value        Float
  risk_factor_type         Int
  copier_status            Int            @default(1)
  max_order_size           Float?
  min_order_size           Float?
  pending_order            Int            @default(1)
  stop_loss                Int            @default(0)
  take_profit              Int            @default(0)
  stop_loss_fixed_format   Int            @default(2)
  take_profit_fixed_format Int            @default(2)
  advancedSettings         Json?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingModels            TradingModel[]

  @@index([userId])
}

model TradingModel {
  id              String      @id @default(cuid())
  userId          String
  masterAccountId String
  configId        String
  name            String
  description     String?
  isPublic        Boolean     @default(false)
  group_id        String?
  ownerId         String?
  isClone         Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  modelConfig     ModelConfig @relation(fields: [configId], references: [id])
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([configId])
}

model SyncConfig {
  id                       String   @id @default(cuid())
  userId                   String
  masterAccountId          String
  slaveAccountId           String
  risk_factor_value        Float
  risk_factor_type         Int
  copier_status            Int      @default(1)
  max_order_size           Float?
  min_order_size           Float?
  pending_order            Int      @default(1)
  stop_loss                Int      @default(0)
  take_profit              Int      @default(0)
  stop_loss_fixed_format   Int      @default(2)
  take_profit_fixed_format Int      @default(2)
  advancedSettings         Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([masterAccountId, slaveAccountId])
  @@index([userId])
}

model CredentialsApi {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CopyRequest {
  id              String            @id @default(cuid())
  followerId      String
  traderId        String
  masterAccountId String
  slaveAccountId  String
  status          CopyRequestStatus @default(PENDING)
  message         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  follower User @relation("SentRequests", fields: [followerId], references: [id], onDelete: Cascade)
  trader   User @relation("ReceivedRequests", fields: [traderId], references: [id], onDelete: Cascade)

  @@index([followerId])
  @@index([traderId])
}

enum CopyRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum UserRole {
  user
  superadmin
  trader
}
